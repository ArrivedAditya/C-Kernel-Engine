#!/usr/bin/env sh
# Enforce high-signal commit messages.
# Format:
#   type(scope): short summary
#
# Example:
#   fix(v7/perf): resolve profile summary path fallback for .ck_build
#   feat(v8/vision): add patch frontend lowering
#   chore(hooks): require scoped commit headers
#
# Optional body (required for key change types):
#   Why: explain intent and impact
#   Test: list verification commands
#
# Knowledge trail (soft prompt for runtime/kernel/perf changes):
#   Docs: updated docs path, or "not needed; <reason>"
#   Nightly: added/updated test surface, or "not needed; <reason>"
#   Research: added notes/analysis, or "not needed; <reason>"
#   Blog: source material for blog agent, or "not needed; <reason>"

set -eu

MSG_FILE="${1:-}"
if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  echo "commit-msg hook error: missing commit message file" >&2
  exit 1
fi

# Drop comments generated by Git and read first non-empty line as header.
CLEAN_MSG="$(sed '/^#/d' "$MSG_FILE")"
HEADER="$(printf '%s\n' "$CLEAN_MSG" | sed -n '/./{p;q;}')"

# Empty message is handled by Git itself.
[ -z "$HEADER" ] && exit 0

# Allow auto-generated commit headers.
case "$HEADER" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

TYPES='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'
HEADER_RE="^(${TYPES})(\\([a-z0-9._/-]+\\))(!)?: .+$"

if ! printf '%s\n' "$HEADER" | grep -Eq "$HEADER_RE"; then
  cat >&2 <<'MSG'
Invalid commit header.

Required format:
  type(scope): summary

Examples:
  feat(v7/train): add run-dir based train suite command
  feat(v8/vision): add patch frontend lowering
  fix(v6.6/rope): keep rotary_dim defaults for missing metadata
  chore(hooks): enforce commit quality checks
MSG
  exit 1
fi

SCOPE="$(printf '%s' "$HEADER" | sed -nE 's/^[a-z]+\(([a-z0-9._/-]+)\)(!)?: .*/\1/p')"
if [ -z "$SCOPE" ]; then
  cat >&2 <<'MSG'
Commit scope is required.

Use:
  type(scope): summary

Examples:
  feat(v8): start vision encoder bring-up
  fix(v7/train): add pairwise rope backward
  perf(kernels): improve q8 gemm dispatch
MSG
  exit 1
fi

# Require line 2 to be blank (standard readable format).
LINE2="$(printf '%s\n' "$CLEAN_MSG" | sed -n '2p')"
if [ -n "${LINE2:-}" ]; then
  echo "Line 2 must be blank between header and body." >&2
  exit 1
fi

SUMMARY="${HEADER#*: }"
SUMMARY_LEN=${#SUMMARY}
if [ "$SUMMARY_LEN" -lt 12 ] || [ "$SUMMARY_LEN" -gt 72 ]; then
  echo "Summary length must be between 12 and 72 characters." >&2
  echo "Current summary (${SUMMARY_LEN}): $SUMMARY" >&2
  exit 1
fi

# Reject obviously vague summaries.
SUMMARY_NORM="$(printf '%s' "$SUMMARY" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')"
for BAD in "update" "updates" "fix" "fixes" "change" "changes" "misc" "wip" "tmp" "work"; do
  if [ "$SUMMARY_NORM" = "$BAD" ] || [ "$SUMMARY_NORM" = "$BAD." ]; then
    echo "Summary is too vague: \"$SUMMARY\"." >&2
    echo "Describe what changed and where." >&2
    exit 1
  fi
done

# Require body for key change types and breaking changes.
TYPE="$(printf '%s' "$HEADER" | sed -E 's/^([a-z]+).*/\1/')"
IS_BREAKING=0
printf '%s' "$HEADER" | grep -q '!:' && IS_BREAKING=1 || true

REQUIRE_BODY=0
case "$TYPE" in
  feat|fix|refactor|perf|revert)
    REQUIRE_BODY=1
    ;;
esac
[ "$IS_BREAKING" -eq 1 ] && REQUIRE_BODY=1

BODY="$(printf '%s\n' "$CLEAN_MSG" | sed -n '3,$p')"
BODY_NONEMPTY="$(printf '%s\n' "$BODY" | sed -n '/./p')"

if [ "$REQUIRE_BODY" -eq 1 ]; then
  if [ -z "$BODY_NONEMPTY" ]; then
    cat >&2 <<'MSG'
Body required for this commit type.
Include at least:
  Why: <intent and impact>
  Test: <commands/results>
MSG
    exit 1
  fi
  if ! printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Why|Context|Reason): '; then
    echo "Body must include a 'Why:' (or Context:/Reason:) line." >&2
    exit 1
  fi
  if ! printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Test|Tests|Validation): '; then
    echo "Body must include a 'Test:' (or Tests:/Validation:) line." >&2
    exit 1
  fi
fi

# Soft knowledge-trail prompts. These do not block commits; they make the
# operator-facing/documentation impact explicit for humans and blog agents.
STAGED_FILES="$(git diff --cached --name-only 2>/dev/null || true)"
KNOWLEDGE_RELEVANT=0
case "$TYPE" in
  feat|fix|refactor|perf)
    KNOWLEDGE_RELEVANT=1
    ;;
esac
if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/kernels/|version/v[0-9.]+/(scripts|templates|kernel_maps|model_maps)/|Makefile|scripts/nightly_runner.py|benchmarks/|research/)'; then
  KNOWLEDGE_RELEVANT=1
fi

if [ "$KNOWLEDGE_RELEVANT" -eq 1 ] && [ -n "$BODY_NONEMPTY" ]; then
  HAS_DOCS=0
  HAS_NIGHTLY=0
  HAS_RESEARCH=0
  HAS_BLOG=0
  printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Docs|Documentation): ' && HAS_DOCS=1 || true
  printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Nightly|CI): ' && HAS_NIGHTLY=1 || true
  printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Research|Analysis): ' && HAS_RESEARCH=1 || true
  printf '%s\n' "$BODY_NONEMPTY" | grep -Eq '^(Blog|Blog-Agent|Blog Agent): ' && HAS_BLOG=1 || true

  if [ "$HAS_DOCS" -eq 0 ] || [ "$HAS_NIGHTLY" -eq 0 ] || [ "$HAS_RESEARCH" -eq 0 ] || [ "$HAS_BLOG" -eq 0 ]; then
    cat >&2 <<'MSG'
Knowledge trail prompt (non-blocking):
  For runtime/kernel/perf/command changes, consider adding:
    Docs: <updated doc path> OR not needed; <reason>
    Nightly: <new/updated CI or make target> OR not needed; <reason>
    Research: <notes/analysis path> OR not needed; <reason>
    Blog: <what a blog agent should read/extract> OR not needed; <reason>
MSG
  fi
fi

exit 0
