          {
            "id": "qkv_packed_proj",
            "op": "qkv_packed_proj"
          },
          {
            "id": "split_qkv",
            "op": "split_qkv_packed"
          },
          {
            "id": "vision_mrope",
            "op": "rope_qk",
            "params": {
              "rope_mode": "vision",
              "position_rank": 4,
              "rotary_width_policy": "full_head_dim",
              "section_policy": "spatial_2d_split_half"
            }
          },
          {
            "id": "attn",
            "op": "attn"
          },
          {
            "id": "attn_out_proj",
            "op": "out_proj"
