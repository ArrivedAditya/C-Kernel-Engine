              },
              {
                "id": "norm",
                "op": "branch_layernorm",
                "params": {
                  "rows_from_config": "vision_merged_tokens",
                  "out_dim_from_config": "projector_in_dim"
                },
                "weight_refs": {
                  "gamma": "v.deepstack.{L}.norm.weight",
                  "beta": "v.deepstack.{L}.norm.bias"
                }
              },
              {
                "id": "fc1",
                "op": "branch_fc1",
                "params": {
