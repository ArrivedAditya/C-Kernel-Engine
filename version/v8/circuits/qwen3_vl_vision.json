        },
        {
          "id": "projector_fc1",
          "op": "projector_fc1"
        },
        {
          "id": "projector_gelu",
          "op": "projector_gelu"
        },
        {
          "id": "projector_fc2",
          "op": "projector_fc2"
        },
        {
          "id": "deepstack_concat",
          "op": "branch_concat",
          "inputs": [
            "footer.projector_fc2.out",
