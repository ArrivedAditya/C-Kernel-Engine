            "op": "gelu"
          },
          {
            "id": "mlp_down",
            "op": "mlp_down"
          },
          {
            "id": "mlp_residual",
            "op": "residual_add"
          }
        ]
      },
      "branches": [
        {
          "name": "deepstack",
          "kind": "fixed_branch",
          "tap": {
            "from": "body.mlp_residual.out",
