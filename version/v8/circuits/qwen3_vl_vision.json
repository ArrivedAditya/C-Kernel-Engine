              },
              {
                "id": "fc2",
                "op": "branch_fc2",
                "params": {
                  "rows_from_config": "vision_merged_tokens",
                  "out_dim_from_config": "projector_out_dim"
                },
                "weight_refs": {
                  "W": "v.deepstack.{L}.fc2.weight",
                  "bias": "v.deepstack.{L}.fc2.bias"
                }
              }
            ]
          },
          "collect": {
            "mode": "concat",
            "axis": "feature",
            "target": "branch.deepstack",
            "rows_from_config": "vision_merged_tokens",
            "slice_dim_from_config": "projector_out_dim",
            "num_slices_from_config": "num_deepstack_layers"
          }
        }
      ],
      "footer": [
        {
          "id": "final_norm",
          "op": "layernorm"
        },
        {
          "id": "merge_main",
          "op": "spatial_merge",
          "params": {
