  "block_types": {
    "vision_encoder": {
      "sequence": [
        "header",
        "body",
        "footer"
      ],
      "header": [
        {
          "id": "patchify",
          "op": "patchify"
        },
        {
          "id": "patch_proj",
          "op": "patch_proj"
        },
        {
          "id": "patch_proj_aux",
          "op": "patch_proj_aux"
