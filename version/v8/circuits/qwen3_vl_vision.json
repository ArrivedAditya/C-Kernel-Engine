          ],
          "params": {
            "rows_from_config": "vision_merged_tokens",
            "main_dim_from_config": "projector_out_dim",
            "branch_slice_dim_from_config": "projector_out_dim",
            "num_branch_slices_from_config": "num_deepstack_layers"
          },
          "axis": "feature",
          "output": "vision_embeddings"
        }
      ]
    }
  }
