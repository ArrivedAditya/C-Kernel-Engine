{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cke.circuit_weight_policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ignore": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pattern", "reason"],
        "properties": {
          "pattern": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "when": {
            "type": "object",
            "additionalProperties": false,
            "required": ["config_key", "equals"],
            "properties": {
              "config_key": {"type": "string", "minLength": 1},
              "equals": {"type": ["string", "number", "integer", "boolean"]}
            }
          }
        }
      }
    },
    "op_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "op", "weights"],
        "properties": {
          "section": {"enum": ["header", "body", "footer", "branch"]},
          "op": {"type": "string", "minLength": 1},
          "weights": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    }
  }
}
