{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cke.v8.numerical_replay_manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "artifacts", "fixtures"],
  "properties": {
    "schema_version": {"const": 1},
    "suite_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "adapter", "artifacts", "shape", "threads", "expected"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
          "adapter": {"enum": ["q4_k_q8_k_production", "q6_k_q8_k_production"]},
          "artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": ["activations", "weights", "expected_output"],
            "properties": {
              "activations": {"type": "string", "minLength": 1},
              "weights": {"type": "string", "minLength": 1},
              "expected_output": {"type": "string", "minLength": 1}
            }
          },
          "shape": {
            "type": "object",
            "additionalProperties": false,
            "required": ["m", "n", "k"],
            "properties": {
              "m": {"type": "integer", "minimum": 1},
              "n": {"type": "integer", "minimum": 1},
              "k": {"type": "integer", "minimum": 256, "multipleOf": 256}
            }
          },
          "weight_offset": {"type": "integer", "minimum": 0},
          "bias_offset": {"type": "integer", "minimum": 0},
          "threads": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "integer", "minimum": 1, "maximum": 1024}
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "required": ["oracle", "comparison"],
            "properties": {
              "oracle": {"const": "llama.cpp_production_graph"},
              "comparison": {"const": "bit_exact"}
            }
          }
        }
      }
    }
  }
}
